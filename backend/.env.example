# Application
PORT=5000
FRONTEND_URL=http://localhost:3000

# ─── Neon PostgreSQL ──────────────────────────────────
# Get from: https://console.neon.tech → Project → Connection Details
# DATABASE_URL = Pooled connection (enable "Pooled connection" toggle)
# DIRECT_URL   = Direct connection (disable "Pooled connection" toggle)
DATABASE_URL=postgresql://USER:PASSWORD@ep-XXXX.REGION.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=10
DIRECT_URL=postgresql://USER:PASSWORD@ep-XXXX.REGION.aws.neon.tech/neondb?sslmode=require

# Redis (use Upstash free tier: https://console.upstash.com)
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=supersecretjwtkey_replace_in_production
JWT_REFRESH_SECRET=supersecretrefreshkey_replace_in_production

# AI / Anthropic API
ANTHROPIC_API_KEY=sk-ant-api03-placeholder-key

# Payments / Stripe
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# AWS S3 / File Storage
AWS_ACCESS_KEY_ID=placeholder_access_key
AWS_SECRET_ACCESS_KEY=placeholder_secret_key
S3_BUCKET_NAME=momplan-documents-dev
AWS_REGION=us-east-1

# Email / Resend
RESEND_API_KEY=re_placeholder
